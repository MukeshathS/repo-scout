# Optional, but strongly recommended for GitHub API rate limits.
GITHUB_TOKEN=

# Required only when REDDIT_ENABLED=true.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=repo-scout/1.0

# Runtime configuration (defaults shown)
MIN_STARS=250
MAX_STALE_DAYS=365
AUTO_APPROVE_SCORE=4.0
GITHUB_SEARCH_ENABLED=true
HN_ENABLED=true
REDDIT_ENABLED=true
AWESOME_ENABLED=true

# Optional path to the editable discovery taxonomy (defaults to config/discovery_taxonomy.toml).
DISCOVERY_TAXONOMY_PATH=config/discovery_taxonomy.toml
